// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ruby-rails-postgres
{
	"name": "Ruby on Rails & Postgres",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/rails/devcontainer/features/sqlite3:1": {},
		"ghcr.io/devcontainers/features/node:1": {
			"nodeGypDependencies": true,
			"version": "lts",
			"pnpmVersion": "latest",
			"nvmVersion": "latest"
		},
		"ghcr.io/jsburckhardt/devcontainer-features/opencode:1": {}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// This can be used to network with other containers or the host.
	// "forwardPorts": [3000, 5432],

	// Pre-create OpenCode auth and config files on the host before the container starts.
	// This prevents Docker from creating them as directories instead of files.
	"initializeCommand": "mkdir -p ~/.local/share/opencode ~/.config/opencode && touch ~/.local/share/opencode/auth.json ~/.config/opencode/opencode.json",

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "cd zurnoDoc && bundle install && rails db:migrate",
	"customizations": {
		"vscode": {
			"extensions": [
				"misogi.ruby-rubocop",
				"oderwat.indent-rainbow",
				"streetsidesoftware.code-spell-checker",
				"eamodio.gitlens"
			]
		}
	}

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
