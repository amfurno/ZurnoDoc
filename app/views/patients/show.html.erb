<%# app/views/patients/show.html.erb %>
<div class="content">
  <h1 class="title"><%= @patient.name %></h1>

  <div class="buttons">
    <%= link_to "Doctors", patient_doctors_path(@patient), class: "button is-info" %>
    <%= link_to "Edit", edit_patient_path(@patient), class: "button is-warning" %>
    <%= button_to "Delete", @patient, method: :delete, class: "button is-danger",
          data: { turbo_confirm: "Delete #{@patient.name}? This will also delete all their doctors." } %>
  </div>

  <%= link_to "Back to Patients", patients_path, class: "button is-light" %>
</div>
