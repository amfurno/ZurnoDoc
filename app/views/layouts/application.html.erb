<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Zurno Doc" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Zurno Doc">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar is-light" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <span class="navbar-item has-text-weight-bold">Zurno Doc</span>
      </div>
      <div class="navbar-menu">
        <div class="navbar-end">
          <div class="navbar-item">
            <% if authenticated? %>
              <%= link_to "Doctors", doctors_path, class: "button is-light mr-2" %>
              <%= button_to "Sign Out", session_path, method: :delete, class: "button is-danger is-light" %>
            <% else %>
              <%= link_to "Sign In", new_session_path, class: "button is-light mr-2" %>
              <%= link_to "Sign Up", new_user_path, class: "button is-primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="notification is-success is-light mx-4 mt-4"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="notification is-warning is-light mx-4 mt-4"><%= flash[:alert] %></div>
    <% end %>

    <%= yield %>
  </body>
</html>
